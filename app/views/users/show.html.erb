<h1 class="display-4">User</h1>

<div style="margin-bottom: 1rem;">
  <a href="<%= users_path %>">Back</a>

  <span style="padding: 0px 4px;">|</span>

  <a href="<%= edit_user_path(@user) %>">Edit</a>

  <span style="padding: 0px 4px;">|</span>

  <a href="<%= user_path(@user) %>" data-turbo-method="delete" data-turbo-confirm="Are you sure?">Destroy</a>
</div>

<table class="table table-bordered" style="max-width: 480px;">
  <tbody>
    <tr>
      <th class="table-light" style="width: 140px;">ID</th>
      <td><%= @user.id %></td>
    </tr>

    <tr>
      <th class="table-light">First Name</th>
      <td><%= @user.first_name %></td>
    </tr>

    <tr>
      <th class="table-light">Last Name</th>
      <td><%= @user.last_name %></td>
    </tr>

    <tr>
      <th class="table-light">Age</th>
      <td><%= @user.age %></td>
    </tr>

    <tr>
      <th class="table-light">Weight</th>
      <td><%= @user.weight %></td>
    </tr>

    <tr>
      <th class="table-light">Smoker</th>
      <td><%= @user.smoker ? 'Yes' : 'No' %></td>
    </tr>
  </tbody>
</table>
