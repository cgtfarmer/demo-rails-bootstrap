<h1 class="display-1">New User</h1>

<div style="margin-bottom: 1rem;">
  <a href="<%= users_path %>">Back</a>
</div>

<form action="<%= users_path %>" method="post">
  <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

  <div>
    <label>First Name</label>
    <input type="text" name="user[first_name]">
  </div>

  <div>
    <label>Last Name</label>
    <input type="text" name="user[last_name]">
  </div>

  <div>
    <label>Age</label>
    <input type="number" name="user[age]">
  </div>

  <div>
    <label>Weight</label>
    <input type="number" step="0.1" name="user[weight]">
  </div>

  <div>
    <label>Smoker</label>
    <input type="checkbox" name="user[smoker]" value="1">
  </div>

  <div>
    <button type="submit">Create User</button>
  </div>
</form>
