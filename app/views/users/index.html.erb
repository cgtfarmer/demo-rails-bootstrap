<h1 class="display-1">Users</h1>

<div>
  <button>New User</button>
</div>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>First Name</th>
      <th>Last Name</th>
      <th>Age</th>
      <th>Weight</th>
      <th>Smoker</th>
      <th></th>
    </tr>
  </thead>

  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user['id'] %></td>
        <td><%= user['first_name'] %></td>
        <td><%= user['last_name'] %></td>
        <td><%= user['age'] %></td>
        <td><%= user['weight'] %></td>
        <td><%= user['smoker'] %></td>
        <td></td>
      </tr>
    <% end %>
  </tbody>
</table>
